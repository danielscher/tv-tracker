@page
@model Home.HomeModel
@section Styles {
    <link rel="stylesheet" href="~/css/Home/index.css" asp-append-version="true" />
}

<div class="main-container">

    <h3>Recently Watched</h3>

    <div class="recently-watched-container">
            @foreach(var um in Model.UserMovies) 
            {
                <div class="media-card">
                    @if(@um.Movie.MediaInfo.PosterPath != null) {
                        <img src="@um.Movie.MediaInfo.PosterPath" alt="@um.Movie.MediaInfo.Title" />
                    }
                    @if(um.Rating != null){
                        <span class="media-rating">
                            @um.Rating
                        </span>
                    }
                </div>
            }
    </div>
</div>