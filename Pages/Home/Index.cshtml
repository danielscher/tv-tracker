@page
@model Home.HomeModel
@section Styles {
    <link rel="stylesheet" href="~/css/Home/index.css" asp-append-version="true" />
}

<div class="main-container">

    <h1>Hello, @Model.ProfileName</h1>

    <div>
        <label>Movies Watched:</label>
        <span>@Model.MoviesCount</span>
        <label>Watch time:</label>
        <span>@TimeFormatting.FormatMinutes(Model.MoviesWatchTime)</span>
    </div>

    <div>
        <label>Shows Watched:</label>
        <span>@Model.SeriesCount</span>
        <label>Watch time:</label>
        <span>@TimeFormatting.FormatMinutes(Model.SeriesWatchTime)</span>

    </div>

    <h3>Recently Watched</h3>

    <div class="card-container">
            @foreach(var recentMedia in Model.RecentlyWatched) 
            {
                <div class="media-card">
                    @if(recentMedia.PosterUrl != null) {
                        <img src="@recentMedia.PosterUrl" alt="@recentMedia.Title" />
                    }
                    @if(recentMedia.Rating != null){
                        <span class="media-rating">
                            @recentMedia.Rating
                        </span>
                    }
                </div>
            }
    </div>
</div>