@using TvTracker.Models.View
@model MediaCardsSectionView

  

@if(Model.MediaViews.Count != 0) { 
    <div class="media-cards-section">

        <h3>@Model.SectionName</h3>

        <div class="card-container">
            @foreach(var mediaView in Model.MediaViews) 
            {
                <a asp-page="@Model.RedirectUrl" asp-route-tmdbId="@mediaView.TmdbId">
                    <div class="media-card">
                        <img src=@mediaView.PosterUrl alt="@mediaView.Title" />
                        @if(mediaView.Rating != null) {
                            <span class="media-rating">
                                @mediaView.Rating
                            </span>
                        }
                        @if(mediaView.ReleaseDate?.CompareTo(DateTime.Now) > 0) {
                            <span class="coming-soon">Coming soon</span>
                        }
                    </div>
                </a>
            }
        </div>
    </div>
}