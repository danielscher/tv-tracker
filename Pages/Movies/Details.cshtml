@page "{tmdbId:int}"
@model Movies.DetailsModel
@section Styles {
    <link rel="stylesheet" href="~/css/Home/index.css" asp-append-version="true" />
}
<div class="main-content">

    <div class="media-banner">
        <img src=@Model.MovieView?.PosterUrl alt="" />
        <div class="media-title">
            <h2>@Model.MovieView?.Title</h2>
        </div>
        @if(Model.MediaControls != null && Model.MovieView != null) {
           <partial name="_MediaControls"
            model="Model.MediaControls" />
        }
    </div>

    <div class="cast-container">
        <h3>Cast</h3>

        <div class="cards-container">  
            @foreach(var member in Model.MovieView?.Cast) {
                <div class="cast-card">
                    @if(member.PosterPath != null) {
                        <img src=@member.PosterPath/>
                        
                    } else {
                        <div class="placeholder-poster"></div>
                    }
                    <span>@member.CharacterName</span>
                    <span>@member.ActorName</span>
                </div>
            }
        </div>

    </div>

</div>

@section Scripts {
    <script type="module">
        import {initMediaControls} from '/js/initMediaControls.js';
        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        initMediaControls(token);
    </script>
}