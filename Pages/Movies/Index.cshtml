@page
@using TvTracker.Models.View
@model Movies.MoviesModel
@Html.AntiForgeryToken()
@section Styles {
    <link rel="stylesheet" href="~/css/Home/index.css" asp-append-version="true" />
}

@{
    ViewData["Title"] = "Movies";
}

<div class="main-container">

    <div>
        <input name="searchQuery" type="text" id="searchBox">
    </div>

    <ul class="search-container"  id="search-results"></ul>

    <div class="user-media-container" id="user-media-content">
        <partial name="_MediaCardsSection" 
         model="@(new MediaCardsSectionView("Watch Later",Model.WatchList))" 
        />

        <partial name="_MediaCardsSection" 
         model="@(new MediaCardsSectionView("History",Model.AlreadyWatch))" 
        />
    </div>
</div>

<script type="module">
    import { searchMediaOnInput } from '/js/search.js';
    searchMediaOnInput("searchBox", "search-results", "?handler=Search","Movies/Details","user-media-content");
</script>